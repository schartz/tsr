---
# We base it on a standard style, then override your specific requests
BasedOnStyle: LLVM

# Use 4 spaces for indentation
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 120

# Keep braces attached to the function declaration
BreakBeforeBraces: Custom
BraceWrapping:
  AfterFunction: false
  AfterClass: false
  AfterControlStatement: Never
  AfterEnum: false
  AfterNamespace: false
  AfterStruct: false
  AfterUnion: false
  BeforeCatch: false
  BeforeElse: false
...
